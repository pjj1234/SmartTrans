# ===== SmartTrans 生产环境变量 =====
# 复制此文件为 server/.env 并填入真实值

# 服务端口（PM2 中通过 ecosystem.config.cjs 设置，这里作为备用）
PORT=28123

# ===== 视觉模型（场景识别）=====
QWEN_API_KEY=sk-your-key-here
QWEN_BASE_URL=https://api.siliconflow.cn/v1
QWEN_VISION_MODEL=Qwen/Qwen3-VL-30B-A3B-Instruct

# ===== 推理模型（严重程度+责任+报告）=====
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_BASE_URL=https://api.siliconflow.cn/v1
DEEPSEEK_MODEL=deepseek-ai/DeepSeek-V4-Flash

# ===== 嵌入模型（RAG 向量检索）=====
EMBEDDING_API_KEY=sk-your-key-here
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B
EMBEDDING_DIM=4096

# ===== MCP 功能 =====
MCP_ENABLED=false

# ===== 日志级别 =====
LOG_LEVEL=INFO

# ===== CORS（生产环境建议限制来源）=====
# 多个来源用逗号分隔，不设置则仅允许本机
# ALLOWED_ORIGINS=http://your-domain.com,https://your-domain.com
